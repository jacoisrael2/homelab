apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: travel-budget
  namespace: travel-budget
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  ingressClassName: nginx
  rules:
  - host: travel-budget.jaco.lab
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: travel-budget-frontend
            port:
              number: 80
